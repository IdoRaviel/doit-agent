"""doit — natural-language shell agent."""

import json
import select
import sys
from pathlib import Path

# Allow running from any directory by adding the project root to sys.path
sys.path.insert(0, str(Path(__file__).resolve().parent))

from src.config import load_config
from src.llm import ask, SYSTEM_PROMPT
from src.shell import run_shell
from src.safety import local_danger_check
from src.history import load_recent, build_messages, append_turn

# Seconds to wait for an answer to a clarification, and how many clarification
# rounds to allow before giving up (guards against a model that loops asking).
CLARIFY_TIMEOUT = 120
MAX_CLARIFY = 3


def read_with_timeout(prompt: str, timeout: int):
    """Print prompt and read one line, waiting at most `timeout` seconds.
    Returns the entered text, or None if the time elapsed with no input."""
    print(prompt, end="", flush=True)
    ready, _, _ = select.select([sys.stdin], [], [], timeout)
    if ready:
        return sys.stdin.readline().rstrip("\n")
    return None


def main():
    if len(sys.argv) < 2:
        print("Usage: doit \"<what you want to do>\"")
        sys.exit(1)

    user_request = " ".join(sys.argv[1:])

    try:
        config = load_config()
    except FileNotFoundError as e:
        print(f"Error: {e}")
        sys.exit(1)

    model = config["model"]

    history = load_recent()
    messages = build_messages(SYSTEM_PROMPT, history, user_request)

    # Ask the model; if it needs to clarify, prompt the user and re-ask with the
    # answer appended, until it returns an actionable response (or we give up).
    clarify_rounds = 0
    while True:
        try:
            response = ask(messages, model)
        except Exception as e:
            print(f"LLM error: {e}")
            sys.exit(1)

        if response.get("type") != "clarify":
            break

        clarify_rounds += 1
        if clarify_rounds > MAX_CLARIFY:
            print("Too many clarification rounds — aborting.")
            sys.exit(0)

        question = response.get("question", "")
        options = response.get("options", []) or []
        print(question)
        for i, opt in enumerate(options, 1):
            print(f"{i}. {opt}")

        answer = read_with_timeout("Your answer: ", CLARIFY_TIMEOUT)
        if answer is None or not answer.strip():
            minutes = CLARIFY_TIMEOUT // 60
            print(f"\nNo answer within {minutes} minute(s) — exiting. "
                  f"Re-run doit when you're ready.")
            append_turn({
                "model": model, "request": user_request, "type": "clarify",
                "question": question, "options": options, "answered": False,
            })
            sys.exit(0)

        # Let the user reply with an option number or free text.
        choice = answer.strip()
        if choice.isdigit() and 1 <= int(choice) <= len(options):
            choice = options[int(choice) - 1]

        messages.append({"role": "assistant", "content": json.dumps(response)})
        messages.append({"role": "user", "content": choice})

    rtype = response.get("type")

    if rtype == "command":
        command = response.get("command", "")
        explanation = response.get("explanation", "")
        llm_safe = response.get("safe", False)
        local_dangerous, local_reason = local_danger_check(command)

        if explanation:
            print(f"# {explanation}")
        print(command)

        # Run directly only if BOTH the LLM and the local check agree it's safe.
        if not llm_safe or local_dangerous:
            reason = local_reason or "this command modifies your system"
            print(f"\n⚠️  This may be dangerous: {reason}.")
            try:
                answer = input("Proceed? [y/N] ").strip().lower()
            except (EOFError, KeyboardInterrupt):
                answer = "n"
                print()
            if answer != "y":
                print("Aborted.")
                append_turn({
                    "model": model,
                    "request": user_request, "type": "command",
                    "command": command, "explanation": explanation,
                    "executed": False,
                })
                sys.exit(0)

        print()
        result = run_shell(command)
        if result["stdout"]:
            print(result["stdout"], end="")
        if result["stderr"]:
            print(result["stderr"], end="", file=sys.stderr)

        # Many commands (touch, rm, mkdir, cd...) are silent on success, so give
        # explicit feedback that the command ran and how it ended.
        if result["returncode"] == 0:
            if not result["stdout"] and not result["stderr"]:
                print("✓ done")
        else:
            print(f"✗ exited with code {result['returncode']}")

        append_turn({
            "model": model,
            "request": user_request, "type": "command",
            "command": command, "explanation": explanation, "executed": True,
            "stdout": result["stdout"], "stderr": result["stderr"],
            "returncode": result["returncode"],
        })

        if result["returncode"] != 0:
            sys.exit(result["returncode"])

    elif rtype == "answer":
        text = response.get("text", "")
        print(text)
        append_turn({"model": model, "request": user_request, "type": "answer", "text": text})

    elif rtype == "impossible":
        text = response.get("text", "")
        print(f"Cannot do that in the shell: {text}")
        append_turn({"model": model, "request": user_request, "type": "impossible", "text": text})

    else:
        print(response.get("text", str(response)))


if __name__ == "__main__":
    main()
